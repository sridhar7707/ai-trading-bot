# Alpaca (paper trading)
ALPACA_KEY=your_alpaca_api_key
ALPACA_SECRET=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets
# ALPACA_BASE_URL=https://api.alpaca.markets  # live (later)

# Telegram
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# HuggingFace
HF_TOKEN=your_huggingface_write_token
HF_REPO_ID=your_username/ai-trading-bot

# FRED (macro signals — free at fred.stlouisfed.org)
FRED_API_KEY=your_fred_api_key

# NewsAPI (headlines for FinBERT — free at newsapi.org, 100 req/day)
NEWSAPI_KEY=your_newsapi_key

# Reddit (WSB sentiment — free at reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=ai-trading-bot/1.0 by your_reddit_username

# Unusual Whales (options flow — optional, free tier at unusualwhales.com)
# UNUSUAL_WHALES_TOKEN=your_token

# Trading Config
TRADING_MODE=paper
INITIAL_CAPITAL=1000
MAX_POSITION_PCT=0.20
STOP_LOSS_PCT=0.04
DAILY_LOSS_LIMIT_PCT=0.05
